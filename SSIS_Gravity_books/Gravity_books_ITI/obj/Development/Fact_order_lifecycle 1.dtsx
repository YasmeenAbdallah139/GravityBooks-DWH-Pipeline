                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    co.order_id AS order_bk,
    co.customer_id,
    co.shipping_method_id,
    -- Get the REAL current status from the main order table
    MAX(os.status_id) AS current_status_id, 
    
    -- 1. Pivot the Dates (Milestones)
    MAX(CASE WHEN os.status_value = 'Order Received' THEN oh.status_date END) AS received_date,
    MAX(CASE WHEN os.status_value = 'Pending Delivery' THEN oh.status_date END) AS pending_delivery_date,
    MAX(CASE WHEN os.status_value = 'Delivered' THEN oh.status_date END) AS delivered_date,
    MAX(CASE WHEN os.status_value = 'Cancelled' THEN oh.status_date END) AS cancelled_date,
    -- Added the Return milestone
    MAX(CASE WHEN os.status_value = 'Returned' THEN oh.status_date END) AS returned_date,

    -- 2. The Math (Using ABS to prevent negative numbers)
    ISNULL(ABS(DATEDIFF(DAY, 
        MAX(CASE WHEN os.status_value = 'Order Received' THEN oh.status_date END), 
        MAX(CASE WHEN os.status_value = 'Pending Delivery' THEN oh.status_date END)
    )), 0) AS days_to_ship,

    ISNULL(ABS(DATEDIFF(DAY, 
        MAX(CASE WHEN os.status_value = 'Pending Delivery' THEN oh.status_date END), 
        MAX(CASE WHEN os.status_value = 'Delivered' THEN oh.status_date END)
    )), 0) AS days_to_deliver,

    ISNULL(ABS(DATEDIFF(DAY, 
        MAX(CASE WHEN os.status_value = 'Order Received' THEN oh.status_date END), 
        MAX(CASE WHEN os.status_value = 'Delivered' THEN oh.status_date END)
    )), 0) AS total_days_to_deliver

FROM gravity_books.dbo.cust_order co
JOIN gravity_books.dbo.order_history oh ON co.order_id = oh.order_id
JOIN gravity_books.dbo.order_status os ON oh.status_id = os.status_id
GROUP BY 
    co.order_id, 
    co.customer_id, 
    co.shipping_method_id</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable"></property>
